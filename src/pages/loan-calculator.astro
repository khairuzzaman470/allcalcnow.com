    display: inline-flex;
    gap: 2px;
    padding: 3px;
    border-radius: 0.75rem;
    background: var(--color-bg);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-border) 80%, transparent);
  }
  .segment-btn {
    border-radius: 0.5rem;
    padding: 0.375rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-muted);
    transition: all 0.2s ease;
  }
  .segment-btn:hover:not(.segment-active) {
    color: var(--color-text);
    background: color-mix(in srgb, var(--color-card) 60%, transparent);
  }
  .segment-active {
    background: var(--color-accent);
    color: white;
    box-shadow: 0 2px 8px color-mix(in srgb, var(--color-accent) 40%, transparent);
  }
  .lc-error {
    background: color-mix(in srgb, var(--color-accent) 8%, white);
    border: 1px solid color-mix(in srgb, var(--color-accent) 25%, transparent);
    color: var(--color-accent);
  }
  .lc-year-row:hover {
    background: color-mix(in srgb, var(--color-accent) 6%, white) !important;
  }
  #pie-chart {
    box-shadow: 0 4px 20px -4px rgba(26, 24, 20, 0.15);
  }
</style>
