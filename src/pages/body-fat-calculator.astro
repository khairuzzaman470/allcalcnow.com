---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import ToolCard from '../components/ToolCard.astro';
import { webApplicationSchema } from '../lib/seo';

const inputClass =
  'pc-input w-full rounded-xl border border-border/70 bg-white px-4 py-3 text-base text-text shadow-sm transition-all placeholder:text-muted/50 focus:border-accent focus:outline-none focus:ring-4 focus:ring-accent/15';
const labelClass = 'mb-2 block text-sm font-semibold tracking-tight text-text';

const relatedTools = [
  { name: 'BMI Calculator', icon: '⚖️', description: 'Find your Body Mass Index (BMI) and check your healthy weight range.', href: '/bmi-calculator' },
  { name: 'Unit Converter', icon: '📏', description: 'Convert length, weight, temperature, volume, and area between metric and imperial scales.', href: '/unit-converter' },
  { name: 'Percentage Calculator', icon: '％', description: 'Three ways to calculate any percentage', href: '/percentage-calculator' },
];

const pageUrl = 'https://allcalcnow.com/body-fat-calculator';
const pageTitle = 'Body Fat Calculator — Calculate Your Body Fat Percentage | AllCalcNow';
const pageDescription =
  'Free body fat calculator at AllCalcNow. Estimate your body fat percentage using the US Navy method with your measurements.';

const faqs = [
  {
    question: 'What is a healthy body fat percentage?',
    answer:
      'Healthy body fat percentages vary by gender and age. For men, a fitness range is 14% to 17%, and the average range is 18% to 24%. For women, a fitness range is 21% to 24%, and the average range is 25% to 31%. Going below essential levels (2% to 5% for men, 10% to 13% for women) is dangerous for your health.',
  },
  {
    question: 'How accurate is the Navy formula?',
    answer:
      'The US Navy body fat formula is highly accurate for a general population, usually within 3% to 4% of direct laboratory measurements (like DXA scans or hydrostatic weighing). It is a cost-effective, non-invasive method that only requires a tape measure. It can, however, overestimate body fat for individuals with high muscle mass (like bodybuilders).',
  },
  {
    question: 'What is the difference between BMI and body fat?',
    answer:
      'Body Mass Index (BMI) is a simple ratio of weight to height, which does not distinguish between muscle mass and fat tissue. An athletic individual with high muscle mass may be classified as "overweight" by BMI. Body fat percentage measures the actual percentage of your weight that is composed of adipose tissue, providing a more detailed picture of body composition and cardiovascular health.',
  },
  {
    question: 'How can I reduce body fat percentage?',
    answer:
      'To reduce body fat, combine a modest caloric deficit (consuming fewer calories than you burn) with consistent strength training to preserve muscle mass. Focus on a high-protein diet, sleep 7 to 9 hours a night, manage stress levels, and combine cardio sessions (like walking or cycling) with structured strength exercises.',
  },
];

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://allcalcnow.com/' },
      { '@type': 'ListItem', position: 2, name: 'Body Fat Calculator', item: pageUrl },
    ],
  },
  webApplicationSchema('Body Fat Calculator', '/body-fat-calculator', pageDescription),
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: { '@type': 'Answer', text: faq.answer },
    })),
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalPath="/body-fat-calculator" schemas={schemas}>
  <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Body Fat Calculator' }]} />

    <header class="mt-6">
      <span class="inline-block rounded-full bg-accent/10 px-3 py-1 text-xs font-bold uppercase tracking-wider text-accent">
        Health & Fitness
      </span>
      <h1 class="mt-3 font-heading text-3xl font-bold tracking-tight text-text sm:text-4xl">Body Fat Calculator</h1>
      <p class="mt-2 max-w-2xl text-base leading-relaxed text-muted">
        Estimate your body fat percentage, lean mass, and fat mass using the popular US Navy Circumference Method.
      </p>
    </header>

    <div class="mt-10 rounded-2xl border border-border/80 bg-card shadow-sm">
      <div class="p-6 lg:p-8">
        <div class="grid gap-8 lg:grid-cols-12">
          <!-- Inputs Column -->
          <div class="lg:col-span-5 space-y-5">
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label for="body-gender" class={labelClass}>Gender</label>
                <select id="body-gender" class={inputClass}>
                  <option value="male" selected>Male</option>
                  <option value="female">Female</option>
                </select>
              </div>
              <div>
                <label for="body-units" class={labelClass}>Unit System</label>
                <select id="body-units" class={inputClass}>
                  <option value="imperial" selected>Imperial (in/lb)</option>
                  <option value="metric">Metric (cm/kg)</option>
                </select>
              </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label for="body-height" class={labelClass}>Height <span class="text-xs font-normal text-muted" id="height-unit-label">(inches)</span></label>
                <input type="number" id="body-height" value="70" min="1" step="any" class={inputClass} />
              </div>
              <div>
                <label for="body-weight" class={labelClass}>Weight <span class="text-xs font-normal text-muted" id="weight-unit-label">(lbs)</span></label>
                <input type="number" id="body-weight" value="170" min="1" step="any" class={inputClass} />
              </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-3">
              <div>
                <label for="body-neck" class={labelClass}>Neck <span class="text-[10px] font-normal text-muted" id="neck-unit-label">(in)</span></label>
                <input type="number" id="body-neck" value="15" min="1" step="any" class={inputClass} />
              </div>
              <div>
                <label for="body-waist" class={labelClass}>Waist <span class="text-[10px] font-normal text-muted" id="waist-unit-label">(in)</span></label>
                <input type="number" id="body-waist" value="34" min="1" step="any" class={inputClass} />
              </div>
              <div id="hip-input-wrapper" class="hidden">
                <label for="body-hip" class={labelClass}>Hip <span class="text-[10px] font-normal text-muted" id="hip-unit-label">(in)</span></label>
                <input type="number" id="body-hip" value="36" min="1" step="any" class={inputClass} />
              </div>
            </div>
          </div>

          <!-- Results Column -->
          <div class="lg:col-span-7 flex flex-col justify-between rounded-2xl bg-navy p-6 text-white sm:p-8 font-medium">
            <div class="space-y-6">
              <p class="text-xs font-semibold uppercase tracking-widest text-white/50">Calculated Body Composition</p>
              
              <div>
                <p class="text-xs font-medium uppercase tracking-wider text-white/60">Estimated Body Fat Percentage</p>
                <p id="result-bfp" class="font-heading text-4xl font-extrabold tracking-tight sm:text-5xl text-white mt-1">0.0%</p>
                <p id="result-category" class="text-sm font-semibold mt-1 text-green-400">—</p>
              </div>
              
              <div class="grid grid-cols-2 gap-4 border-t border-white/10 pt-6">
                <div>
                  <p class="text-xs font-medium uppercase tracking-wider text-white/60">Total Fat Mass</p>
                  <p id="result-fat-mass" class="font-heading text-2xl font-bold text-white mt-1">0.0 lbs</p>
                </div>
                <div>
                  <p class="text-xs font-medium uppercase tracking-wider text-white/60">Total Lean Mass</p>
                  <p id="result-lean-mass" class="font-heading text-2xl font-bold text-green-400 mt-1">0.0 lbs</p>
                </div>
              </div>
            </div>

            <div class="mt-6 border-t border-white/10 pt-4">
              <p id="result-detail" class="text-sm text-white/80 leading-relaxed">
                —
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Blog Section -->
    <article class="seo-content mt-14 max-w-3xl border-t border-border pt-10" itemscope itemtype="https://schema.org/Article">
      <meta itemprop="headline" content="Body Fat Calculator" />
      <meta itemprop="description" content={pageDescription} />
      
      <h1 class="font-heading text-2xl font-bold text-text sm:text-3xl" itemprop="name">Body Fat Calculator</h1>
      <p class="mt-4 text-base leading-relaxed text-muted" itemprop="description">
        Improving your physical fitness and overall health requires measuring more than just your weight. The <strong class="font-semibold text-text">Body Fat Calculator</strong> estimates your body fat percentage—the proportion of your body mass composed of fat tissue relative to lean mass (muscle, bone, and water). Employing the US Navy Circumference Method, this tool uses simple body measurements to evaluate your general body composition.
      </p>

      <nav class="mt-6 rounded-xl border border-border/80 bg-bg/60 p-4" aria-label="Table of contents">
        <p class="text-xs font-bold uppercase tracking-wider text-muted">On this page</p>
        <ol class="mt-2 list-inside list-decimal space-y-1 text-sm font-medium text-text">
          <li><a href="#what-is-body-fat-percentage" class="text-accent hover:underline">What is Body Fat Percentage?</a></li>
          <li><a href="#healthy-body-fat-ranges" class="text-accent hover:underline">Healthy Body Fat Ranges for Men and Women</a></li>
          <li><a href="#how-to-reduce-body-fat" class="text-accent hover:underline">How to Reduce Body Fat</a></li>
          <li><a href="#frequently-asked-questions" class="text-accent hover:underline">Frequently Asked Questions</a></li>
        </ol>
      </nav>

      <section id="what-is-body-fat-percentage" class="mt-10 scroll-mt-24">
        <h2 class="font-heading text-xl font-bold text-text">What is Body Fat Percentage?</h2>
        <p class="mt-3 leading-relaxed text-muted">
          Your body fat percentage is the total mass of fat divided by your total body weight, multiplied by 100. Fat is classified into two types: essential fat and storage fat.
        </p>
        <p class="mt-3 leading-relaxed text-muted">
          Essential fat is necessary to maintain life and reproductive functions. It plays a critical role in temperature regulation, hormone synthesis, vitamin absorption, and internal organ cushioning. Storage fat represents accumulated energy reserves stored in adipose tissue, which varies based on diet, activity levels, and genetics. Keeping storage fat within healthy bounds reduces the risk of chronic conditions such as type 2 diabetes, high blood pressure, and cardiovascular diseases.
        </p>
      </section>

      <section id="healthy-body-fat-ranges" class="mt-10 scroll-mt-24">
        <h2 class="font-heading text-xl font-bold text-text">Healthy Body Fat Ranges for Men and Women</h2>
        <p class="mt-3 leading-relaxed text-muted">
          Healthy body fat percentages differ significantly between men and women due to biological and hormonal variations. Women require higher body fat levels to support reproductive health and endocrine functions.
        </p>
        <p class="mt-3 leading-relaxed text-muted">
          The American Council on Exercise (ACE) lists the following body fat classification standards:
        </p>
        <div class="mt-4 overflow-auto rounded-xl border border-border/80 bg-white shadow-sm">
          <table class="w-full text-left text-sm text-text">
            <thead class="bg-navy text-xs uppercase tracking-wider text-white">
              <tr>
                <th class="px-4 py-3 font-semibold">Category</th>
                <th class="px-4 py-3 font-semibold">Men</th>
                <th class="px-4 py-3 font-semibold">Women</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border/60">
              <tr>
                <td class="px-4 py-3 font-bold">Essential Fat</td>
                <td class="px-4 py-3">2% – 5%</td>
                <td class="px-4 py-3">10% – 13%</td>
              </tr>
              <tr class="bg-bg/25">
                <td class="px-4 py-3 font-bold text-green-600">Athletes</td>
                <td class="px-4 py-3 text-green-600">6% – 13%</td>
                <td class="px-4 py-3 text-green-600">14% – 20%</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-bold text-green-600">Fitness</td>
                <td class="px-4 py-3 text-green-600">14% – 17%</td>
                <td class="px-4 py-3 text-green-600">21% – 24%</td>
              </tr>
              <tr class="bg-bg/25">
                <td class="px-4 py-3 font-bold text-yellow-600">Average</td>
                <td class="px-4 py-3 text-yellow-600">18% – 24%</td>
                <td class="px-4 py-3 text-yellow-600">25% – 31%</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-bold text-red-600">Obese</td>
                <td class="px-4 py-3 text-red-600">25% or higher</td>
                <td class="px-4 py-3 text-red-600">32% or higher</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section id="how-to-reduce-body-fat" class="mt-10 scroll-mt-24">
        <h2 class="font-heading text-xl font-bold text-text">How to Reduce Body Fat</h2>
        <p class="mt-3 leading-relaxed text-muted">
          Lowering your body fat percentage requires a different strategy than simply losing weight. The objective is to lose fat mass while preserving lean muscle mass.
        </p>
        <ul class="mt-3 list-disc space-y-2 pl-5 text-muted leading-relaxed">
          <li><strong class="text-text">Maintain a Caloric Deficit:</strong> Consume fewer calories than your body burns. A daily deficit of 300 to 500 calories promotes safe, sustainable fat loss (around 0.5 to 1 pound per week).</li>
          <li><strong class="text-text">Consume High Protein:</strong> Higher protein intake preserves lean muscle tissue during a caloric deficit and increases satiety, making it easier to stick to your diet.</li>
          <li><strong class="text-text">Strength Training:</strong> Lifting weights or performing bodyweight resistance training signals your body to keep its muscle mass, ensuring that the weight you lose comes from fat rather than muscle.</li>
          <li><strong class="text-text">Prioritize Sleep:</strong> Sleep deprivation increases cortisol (stress hormone) and ghrelin (hunger hormone), making fat loss significantly more difficult and increasing the likelihood of muscle loss. Aim for 7 to 9 hours of sleep each night.</li>
        </ul>
      </section>

      <section id="frequently-asked-questions" class="mt-10 scroll-mt-24">
        <h2 class="font-heading text-xl font-bold text-text">Frequently Asked Questions</h2>
        <div class="mt-6 space-y-4">
          {faqs.map((faq, i) => (
            <details class="group rounded-xl border border-border/80 bg-card open:ring-2 open:ring-accent/20" open={i === 0}>
              <summary class="cursor-pointer list-none px-5 py-4 font-heading text-base font-bold text-text marker:content-none [&::-webkit-details-marker]:hidden">
                <span class="flex items-center justify-between gap-3">
                  {faq.question}
                  <span class="shrink-0 text-accent transition-transform group-open:rotate-45" aria-hidden="true">+</span>
                </span>
              </summary>
              <div class="border-t border-border/60 px-5 pb-4 pt-2">
                <p class="leading-relaxed text-muted">{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </section>

      <p class="mt-10 rounded-xl bg-accent/5 px-4 py-3 text-sm leading-relaxed text-muted ring-1 ring-accent/20">
        <strong class="text-text">Disclaimer:</strong> The results provided by this calculator are estimates based on standardized mathematical averages. They should not replace direct clinical measurements like dual-energy X-ray absorptiometry (DXA) or body composition scans conducted by a physician.
      </p>
    </article>

    <section class="mt-14 border-t border-border pt-10">
      <h2 class="font-heading text-xl font-bold text-text">More Free Calculators on AllCalcNow</h2>
      <ul class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
        {relatedTools.map((tool) => (
          <li><ToolCard name={tool.name} description={tool.description} href={tool.href} icon={tool.icon} /></li>
        ))}
      </ul>
    </section>
  </div>
</BaseLayout>

<script>
  const genderSelect = document.getElementById('body-gender');
  const unitSelect = document.getElementById('body-units');

  const heightInput = document.getElementById('body-height');
  const weightInput = document.getElementById('body-weight');
  const neckInput = document.getElementById('body-neck');
  const waistInput = document.getElementById('body-waist');
  const hipInput = document.getElementById('body-hip');

  const hipWrapper = document.getElementById('hip-input-wrapper');

  const heightLabel = document.getElementById('height-unit-label');
  const weightLabel = document.getElementById('weight-unit-label');
  const neckLabel = document.getElementById('neck-unit-label');
  const waistLabel = document.getElementById('waist-unit-label');
  const hipLabel = document.getElementById('hip-unit-label');

  const resultBfpEl = document.getElementById('result-bfp');
  const resultCategoryEl = document.getElementById('result-category');
  const resultFatMassEl = document.getElementById('result-fat-mass');
  const resultLeanMassEl = document.getElementById('result-lean-mass');
  const resultDetailEl = document.getElementById('result-detail');

  function updateInputLabels() {
    const isMetric = unitSelect?.value === 'metric';
    
    if (heightLabel) heightLabel.textContent = isMetric ? '(cm)' : '(inches)';
    if (weightLabel) weightLabel.textContent = isMetric ? '(kg)' : '(lbs)';
    if (neckLabel) neckLabel.textContent = isMetric ? '(cm)' : '(in)';
    if (waistLabel) waistLabel.textContent = isMetric ? '(cm)' : '(in)';
    if (hipLabel) hipLabel.textContent = isMetric ? '(cm)' : '(in)';
  }

  function handleGenderChange() {
    const isFemale = genderSelect?.value === 'female';
    if (hipWrapper) {
      hipWrapper.classList.toggle('hidden', !isFemale);
    }
  }

  function getCategory(gender, bfp) {
    if (gender === 'male') {
      if (bfp < 2) return { name: 'Below Essential Fat 🛑', color: 'text-red-400' };
      if (bfp <= 5) return { name: 'Essential Fat 🔵', color: 'text-blue-400' };
      if (bfp <= 13) return { name: 'Athletes 🎉', color: 'text-green-400' };
      if (bfp <= 17) return { name: 'Fitness 🎉', color: 'text-green-400' };
      if (bfp <= 24) return { name: 'Average 🟡', color: 'text-yellow-400' };
      return { name: 'Obese 🛑', color: 'text-red-400' };
    } else {
      if (bfp < 10) return { name: 'Below Essential Fat 🛑', color: 'text-red-400' };
      if (bfp <= 13) return { name: 'Essential Fat 🔵', color: 'text-blue-400' };
      if (bfp <= 20) return { name: 'Athletes 🎉', color: 'text-green-400' };
      if (bfp <= 24) return { name: 'Fitness 🎉', color: 'text-green-400' };
      if (bfp <= 31) return { name: 'Average 🟡', color: 'text-yellow-400' };
      return { name: 'Obese 🛑', color: 'text-red-400' };
    }
  }

  function calculate() {
    const gender = genderSelect?.value || 'male';
    const units = unitSelect?.value || 'imperial';
    
    let height = parseFloat(heightInput?.value || '0');
    let weight = parseFloat(weightInput?.value || '0');
    let neck = parseFloat(neckInput?.value || '0');
    let waist = parseFloat(waistInput?.value || '0');
    let hip = parseFloat(hipInput?.value || '0');

    if (height <= 0 || weight <= 0 || neck <= 0 || waist <= 0 || (gender === 'female' && hip <= 0)) {
      [resultBfpEl, resultCategoryEl, resultFatMassEl, resultLeanMassEl].forEach(el => {
        if (el) el.textContent = '—';
      });
      if (resultDetailEl) resultDetailEl.textContent = 'Please enter valid positive measurements.';
      return;
    }

    const originalWeight = weight;
    const weightLabelStr = units === 'metric' ? 'kg' : 'lbs';

    // Normalize measurements to inches for Navy formula
    if (units === 'metric') {
      height = height / 2.54;
      weight = weight * 2.2046226218;
      neck = neck / 2.54;
      waist = waist / 2.54;
      hip = hip / 2.54;
    }

    let bfp = 0;
    if (gender === 'male') {
      if (waist <= neck) {
        if (resultBfpEl) resultBfpEl.textContent = '—';
        if (resultDetailEl) resultDetailEl.textContent = 'Waist must be larger than neck circumference.';
        return;
      }
      bfp = 86.010 * Math.log10(waist - neck) - 70.041 * Math.log10(height) + 36.76;
    } else {
      if (waist + hip <= neck) {
        if (resultBfpEl) resultBfpEl.textContent = '—';
        if (resultDetailEl) resultDetailEl.textContent = 'Sum of waist and hips must be larger than neck.';
        return;
      }
      bfp = 163.205 * Math.log10(waist + hip - neck) - 97.684 * Math.log10(height) - 78.387;
    }

    if (bfp < 0) bfp = 0;

    const fatMassPounds = weight * (bfp / 100);
    const leanMassPounds = weight - fatMassPounds;

    // Convert masses back to metric if selected
    let displayFatMass = fatMassPounds;
    let displayLeanMass = leanMassPounds;

    if (units === 'metric') {
      displayFatMass = fatMassPounds / 2.2046226218;
      displayLeanMass = leanMassPounds / 2.2046226218;
    }

    const cat = getCategory(gender, bfp);

    // Update results
    if (resultBfpEl) resultBfpEl.textContent = `${bfp.toFixed(1)}%`;
    if (resultCategoryEl) {
      resultCategoryEl.textContent = cat.name;
      resultCategoryEl.className = `text-sm font-semibold mt-1 ${cat.color}`;
    }
    if (resultFatMassEl) resultFatMassEl.textContent = `${displayFatMass.toFixed(1)} ${weightLabelStr}`;
    if (resultLeanMassEl) resultLeanMassEl.textContent = `${displayLeanMass.toFixed(1)} ${weightLabelStr}`;

    if (resultDetailEl) {
      resultDetailEl.textContent = `For a ${gender} weighing ${originalWeight} ${weightLabelStr}, an estimated body fat of ${bfp.toFixed(1)}% means you have ${displayFatMass.toFixed(1)} ${weightLabelStr} of body fat and ${displayLeanMass.toFixed(1)} ${weightLabelStr} of lean body mass.`;
    }
  }

  // Bind events
  [genderSelect, unitSelect].forEach(el => {
    el?.addEventListener('change', () => {
      handleGenderChange();
      updateInputLabels();
      calculate();
    });
  });

  [heightInput, weightInput, neckInput, waistInput, hipInput].forEach(el => {
    el?.addEventListener('input', calculate);
  });

  // Init
  handleGenderChange();
  updateInputLabels();
  calculate();
</script>
