---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const pageTitle = "AllCalcNow Blog — Free Calculator Guides and Finance Tips";
const pageDescription = "Free guides on finance, health and everyday calculations from AllCalcNow. Tips to help you make smarter decisions.";
const pageUrl = "https://allcalcnow.com/blog";

const posts = [
  {
    title: "How to Calculate Your Mortgage Payment in 2026: A Complete Step-by-Step Guide",
    description: "Ready to buy a home or refinance? Learn how to calculate your monthly payment manually using the amortization formula and see how PITI affects your costs.",
    href: "/blog/how-to-calculate-mortgage-payment",
    category: "Finance & Money",
    readTime: "8 Min Read",
    date: "May 23, 2026",
    icon: "🏠"
  },
  {
    title: "How to Calculate Your BMI: Complete Guide, Formula & Weight Charts",
    description: "Learn the math behind Body Mass Index (BMI). We break down metric and imperial formulas, check official WHO categories, and look at the health limitations of BMI.",
    href: "/blog/how-to-calculate-bmi",
    category: "Health & Fitness",
    readTime: "7 Min Read",
    date: "May 23, 2026",
    icon: "⚖️"
  },
  {
    title: "What is Compound Interest? How Your Money Grows Over Time",
    description: "Discover the mathematical formula for compound interest, compare simple and compound returns, understand compounding frequencies, and see the power of starting early.",
    href: "/blog/what-is-compound-interest",
    category: "Finance & Money",
    readTime: "10 Min Read",
    date: "May 23, 2026",
    icon: "📈"
  },
  {
    title: "What is VAT? A Complete Beginner's Guide to Value Added Tax",
    description: "Understand Value Added Tax (VAT), compare it to sales tax, learn the exact formulas to add or remove VAT, and review standard VAT brackets in the UK and Europe.",
    href: "/blog/vat-explained",
    category: "Finance & Money",
    readTime: "6 Min Read",
    date: "May 23, 2026",
    icon: "🧾"
  }
];

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://allcalcnow.com/" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": pageUrl }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "AllCalcNow Blog",
    "url": pageUrl,
    "description": pageDescription
  }
];
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalPath="/blog" schemas={schemas}>
  <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    
    <!-- Breadcrumb Navigation -->
    <div class="mb-6">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Blog' }
      ]} />
    </div>

    <!-- Hero Section -->
    <header class="rounded-3xl bg-gradient-to-br from-amber-50 via-white to-orange-50/60 px-6 py-12 text-center ring-1 ring-amber-200/50 sm:px-12 sm:py-16">
      <p class="font-heading text-lg font-bold tracking-wider text-accent uppercase">
        Guides & Tutorials
      </p>
      <h1 class="mt-4 font-heading text-3xl font-extrabold tracking-tight text-text sm:text-4xl lg:text-5xl">
        AllCalcNow Blog
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-muted sm:text-lg">
        Free, step-by-step guides on finance, health, and everyday calculations. Learn the math behind our tools and make smarter decisions.
      </p>
    </header>

    <!-- Articles Grid -->
    <main class="mt-12">
      <h2 class="sr-only">Latest Articles</h2>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-2">
        {posts.map((post) => (
          <article class="group relative flex flex-col rounded-2xl border border-border bg-card p-6 shadow-sm transition-all duration-300 hover:border-accent/30 hover:shadow-md hover:-translate-y-0.5">
            <div class="flex items-center justify-between text-xs text-muted">
              <span class="inline-flex items-center gap-1.5 rounded-full bg-accent/10 px-3 py-1 font-bold text-accent">
                {post.category}
              </span>
              <span class="font-semibold">{post.readTime}</span>
            </div>
            
            <div class="mt-4 flex gap-4">
              <span class="text-4xl select-none" aria-hidden="true">{post.icon}</span>
              <div>
                <h3 class="font-heading text-xl font-bold leading-snug text-text group-hover:text-accent">
                  <a href={post.href} class="after:absolute after:inset-0">
                    {post.title}
                  </a>
                </h3>
                <p class="mt-1 text-xs text-muted font-semibold">{post.date}</p>
              </div>
            </div>

            <p class="mt-4 flex-1 text-sm leading-relaxed text-muted">
              {post.description}
            </p>

            <div class="mt-6 flex items-center gap-1 text-sm font-bold text-accent" aria-hidden="true">
              Read Guide <span class="transition-transform group-hover:translate-x-1">→</span>
            </div>
          </article>
        ))}
      </div>
    </main>

    <!-- Back to Home CTA -->
    <div class="mt-16 text-center">
      <a
        href="/"
        class="inline-flex items-center justify-center rounded-2xl bg-accent px-8 py-4 text-base font-bold text-white shadow-lg shadow-accent/25 transition-all hover:-translate-y-0.5 hover:shadow-xl hover:shadow-accent/30"
      >
        ← Explore All Calculators
      </a>
    </div>

  </div>
</BaseLayout>
