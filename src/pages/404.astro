---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';

const pageTitle = 'Page Not Found | AllCalcNow';
const pageDescription = 'The page you are looking for does not exist. Explore our list of free online calculators for finance, health, and math.';

const popularCalculators = [
  { name: 'Age Calculator', icon: '🎂', description: 'Find your exact age in years, months and days', href: '/age-calculator' },
  { name: 'Mortgage Calculator', icon: '🏠', description: 'Monthly payments, interest, and amortization', href: '/mortgage-calculator' },
  { name: 'VAT Calculator', icon: '🧾', description: 'Add or remove VAT from any price', href: '/vat-calculator' },
];
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalPath="/404">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8 text-center">
    <div class="max-w-md mx-auto">
      <span class="text-7xl" role="img" aria-label="Magnifying glass">🔍</span>
      <h1 class="mt-6 font-heading text-4xl font-extrabold tracking-tight text-text sm:text-5xl">
        404 - Page Not Found
      </h1>
      <p class="mt-4 text-base text-muted leading-relaxed">
        Sorry, we couldn't find the page you're looking for. It might have been moved, or the URL might be incorrect.
      </p>
      
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center rounded-2xl bg-accent px-6 py-3.5 text-sm font-bold text-white shadow-md shadow-accent/15 transition-all hover:-translate-y-0.5 hover:shadow-lg"
        >
          Go to Home
        </a>
        <a
          href="/blog"
          class="inline-flex items-center justify-center rounded-2xl bg-card border border-border/85 px-6 py-3.5 text-sm font-bold text-text hover:bg-bg/40 transition-all hover:-translate-y-0.5"
        >
          Read Our Blog
        </a>
      </div>
    </div>

    <!-- Popular tools suggestion -->
    <div class="mt-20 border-t border-border/60 pt-16">
      <h2 class="font-heading text-2xl font-bold text-text">Try one of our popular calculators</h2>
      <ul class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 text-left">
        {popularCalculators.map((c) => (
          <li>
            <ToolCard name={c.name} description={c.description} href={c.href} icon={c.icon} />
          </li>
        ))}
      </ul>
    </div>
  </div>
</BaseLayout>
