---
interface Props {
  name: string;
  description: string;
  href: string;
  icon: string;
}

const { name, description, href, icon } = Astro.props;
---

<article class="group relative flex h-full flex-col rounded-xl border border-border bg-card p-5 shadow-sm transition-all hover:border-accent/30 hover:shadow-md">
  <span class="text-3xl leading-none" aria-hidden="true">{icon}</span>
  <h2 class="mt-3 font-heading text-lg font-bold text-text group-hover:text-accent">
    <a href={href} class="after:absolute after:inset-0">{name}</a>
  </h2>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{description}</p>
  <span class="mt-4 text-sm font-semibold text-accent" aria-hidden="true">→</span>
</article>
