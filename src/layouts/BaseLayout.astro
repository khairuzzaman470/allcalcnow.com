---
import '../styles/global.css';
// Note: Astro <script> blocks compile to type="module" which is deferred by default.
// No DOMContentLoaded wrapping needed — the browser already defers them safely.

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  /** JSON-LD objects for structured data (FAQPage, BreadcrumbList, etc.) */
  schemas?: Record<string, unknown>[];
}

const { title, description, canonicalPath = Astro.url.pathname, schemas = [] } = Astro.props;
const siteName = 'AllCalcNow';
const siteUrl = (Astro.site?.href ?? 'https://allcalcnow.com').replace(/\/$/, '');
const baseTitle = title.replace(/\s*\|\s*AllCalcNow\s*$/i, '').trim();
const fullTitle = baseTitle.includes(siteName) ? baseTitle : `${baseTitle} | ${siteName}`;
const canonicalURL = new URL(
  Astro.url.pathname.replace(/\/$/, ''),
  'https://allcalcnow.com'
);
const ogImageUrl = new URL('/favicon.svg', `${siteUrl}/`).href;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- CRITICAL CSS: inlined so first paint needs zero external round-trips -->
    <style>
      /* Design tokens used above the fold */
      :root {
        --color-navy: #1a1814;
        --color-bg: #f7f5f0;
        --color-accent: #e8552c;
        --color-text: #1a1814;
        --color-muted: #7a7670;
        --color-border: #e4e0d8;
        --font-base: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif;
      }
      /* Box-sizing reset */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      /* Body shell */
      html { scroll-behavior: smooth; }
      body {
        display: flex;
        min-height: 100svh;
        flex-direction: column;
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: var(--font-base);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      /* Header */
      header { background-color: var(--color-navy); color: #fff; }
      /* Header inner container */
      .site-header-inner {
        margin-left: auto;
        margin-right: auto;
        max-width: 72rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem;
      }
      @media (min-width: 640px)  { .site-header-inner { padding: 1rem 1.5rem; } }
      @media (min-width: 1024px) { .site-header-inner { padding: 1rem 2rem; } }
      /* Logo */
      .site-logo {
        font-family: var(--font-base);
        font-size: 1.25rem;
        font-weight: 700;
        letter-spacing: -0.025em;
        color: #fff;
        text-decoration: none;
      }
      @media (min-width: 640px) { .site-logo { font-size: 1.5rem; } }
      .site-logo .logo-accent { color: var(--color-accent); }
      /* Nav */
      .site-nav { display: flex; align-items: center; gap: 1.5rem; font-size: 0.875rem; }
      .site-nav a { color: rgba(255,255,255,0.8); text-decoration: none; }
      .site-nav a.active { color: var(--color-accent); font-weight: 600; }
      /* Main flex-grow */
      main { flex: 1 1 0%; }
      /* Prevent FOUT layout shift */
      h1, h2, h3, h4 { font-family: var(--font-base); }
    </style>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- DNS prefetch for external domains -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://open.er-api.com" />
    <!-- Preconnect for Google Fonts (critical path) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Async font loading: preload → swap to stylesheet on load; noscript fallback -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      />
    </noscript>
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {
      schemas.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }
    <!-- Google Analytics — G-N03GK8RZF1 (loaded after page render via defer) -->
    <script defer src="https://www.googletagmanager.com/gtag/js?id=G-N03GK8RZF1"></script>
    <script defer is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-N03GK8RZF1');
    </script>
  </head>
  <body>
    <header>
      <div class="site-header-inner">
        <a href="/" class="site-logo hover:opacity-90">
          <span class="logo-accent">All</span>CalcNow
        </a>
        <nav class="site-nav" aria-label="Main">
          {
            (() => {
              const normalizedPath = Astro.url.pathname.replace(/\/$/, '') || '/';
              return (
                <>
                  <a href="/" class={normalizedPath === '/' ? 'active' : ''}>All Calculators</a>
                  <a href="/blog" class={normalizedPath.startsWith('/blog') ? 'active' : ''}>Blog</a>
                  <a href="/about" class={normalizedPath === '/about' ? 'active' : ''}>About</a>
                  <a href="/contact" class={normalizedPath === '/contact' ? 'active' : ''}>Contact</a>
                </>
              );
            })()
          }
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="border-t border-border/10 bg-[#11100e] text-white/60 transition-colors duration-300">
      <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
        <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5">
          <!-- Column 1: Brand Info -->
          <div class="lg:col-span-1">
            <a href="/" class="font-heading text-xl font-bold tracking-tight text-white hover:opacity-90 transition-opacity duration-200">
              <span class="text-accent">All</span>CalcNow
            </a>
            <p class="mt-3 text-sm leading-relaxed text-white/50">
              Fast, private, and accurate online calculators. All free, all the time.
            </p>
            <p class="mt-6 text-xs text-white/30">
              &copy; {new Date().getFullYear()} AllCalcNow.com.<br />
              All rights reserved.
            </p>
          </div>

          <!-- Column 2: Finance & Money -->
          <div>
            <p class="font-heading text-xs font-bold uppercase tracking-wider text-white/90">Finance & Money</p>
            <ul class="mt-4 space-y-2.5 text-sm">
              <li>
                <a href="/mortgage-calculator" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  Mortgage Calculator
                </a>
              </li>
              <li>
                <a href="/loan-calculator" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  Loan Calculator
                </a>
              </li>
              <li>
                <a href="/compound-interest-calculator" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  Compound Interest
                </a>
              </li>
              <li>
                <a href="/currency-converter" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  Currency Converter
                </a>
              </li>
              <li>
                <a href="/vat-calculator" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  VAT Calculator
                </a>
              </li>
              <li>
                <a href="/salary-calculator" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  Salary Calculator
                </a>
              </li>
              <li>
                <a href="/retirement-calculator" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  Retirement Calculator
                </a>
              </li>
              <li>
                <a href="/electricity-bill-calculator" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  Electricity Bill
                </a>
              </li>
            </ul>
          </div>

          <!-- Column 3: Everyday Math -->
          <div>
            <p class="font-heading text-xs font-bold uppercase tracking-wider text-white/90">Everyday Math</p>
            <ul class="mt-4 space-y-2.5 text-sm">
              <li>
                <a href="/percentage-calculator" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  Percentage Calculator
                </a>
              </li>
              <li>
                <a href="/discount-calculator" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  Discount Calculator
                </a>
              </li>
              <li>
                <a href="/unit-converter" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  Unit Converter
                </a>
              </li>
              <li>
                <a href="/fuel-cost-calculator" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  Fuel Cost Calculator
                </a>
              </li>
              <li>
                <a href="/gpa-calculator" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  GPA Calculator
                </a>
              </li>
              <li>
                <a href="/tip-calculator" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  Tip Calculator
                </a>
              </li>
            </ul>
          </div>

          <!-- Column 4: Health & Time -->
          <div>
            <p class="font-heading text-xs font-bold uppercase tracking-wider text-white/90">Health & Time</p>
            <ul class="mt-4 space-y-2.5 text-sm">
              <li>
                <a href="/bmi-calculator" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  BMI Calculator
                </a>
              </li>
              <li>
                <a href="/body-fat-calculator" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  Body Fat Calculator
                </a>
              </li>
              <li>
                <a href="/age-calculator" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  Age Calculator
                </a>
              </li>
              <li>
                <a href="/date-difference-calculator" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  Date Difference
                </a>
              </li>
              <li>
                <a href="/due-date-calculator" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  Due Date Calculator
                </a>
              </li>
            </ul>
          </div>

          <!-- Column 5: Company & Resources -->
          <div>
            <p class="font-heading text-xs font-bold uppercase tracking-wider text-white/90">Company</p>
            <ul class="mt-4 space-y-2.5 text-sm">
              <li>
                <a href="/blog" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  Blog & Articles
                </a>
              </li>
              <li>
                <a href="/about" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  About Us
                </a>
              </li>
              <li>
                <a href="/contact" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  Contact
                </a>
              </li>
              <li>
                <a href="/privacy-policy" class="transition-all duration-200 hover:text-white hover:translate-x-1 inline-block">
                  Privacy Policy
                </a>
              </li>
            </ul>
          </div>
        </div>

        <!-- Bottom Bar / Disclaimer -->
        <div class="mt-12 border-t border-white/5 pt-8 text-center text-xs text-white/40 leading-relaxed">
          <p class="max-w-3xl mx-auto">
            Disclaimer: All calculations on AllCalcNow.com are for reference purposes only. 
            We make no representations or warranties of any kind concerning the accuracy of the calculations. 
            Always consult a qualified professional before making financial, medical, or legal decisions.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
