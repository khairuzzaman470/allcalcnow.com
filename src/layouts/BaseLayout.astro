---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  /** JSON-LD objects for structured data (FAQPage, BreadcrumbList, etc.) */
  schemas?: Record<string, unknown>[];
}

const { title, description, canonicalPath = Astro.url.pathname, schemas = [] } = Astro.props;
const siteName = 'AllCalcNow';
const siteUrl = (Astro.site?.href ?? 'https://allcalcnow.com').replace(/\/$/, '');
const baseTitle = title.replace(/\s*\|\s*AllCalcNow\s*$/i, '').trim();
const fullTitle = `${baseTitle} | ${siteName}`;
const canonicalUrl = new URL(canonicalPath, `${siteUrl}/`).href;
const ogImageUrl = new URL('/favicon.svg', `${siteUrl}/`).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {
      schemas.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }
    <!-- Google Analytics — G-N03GK8RZF1 -->
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-N03GK8RZF1"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-N03GK8RZF1');
    </script>
  </head>
  <body class="flex min-h-screen flex-col">
    <header class="bg-navy text-white">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8">
        <a href="/" class="font-heading text-xl font-bold tracking-tight hover:opacity-90 sm:text-2xl">
          <span class="text-accent">All</span>CalcNow
        </a>
        <nav class="flex items-center gap-6 text-sm" aria-label="Main">
          {
            (() => {
              const normalizedPath = Astro.url.pathname.replace(/\/$/, '') || '/';
              return (
                <>
                  <a href="/" class={normalizedPath === '/' ? "text-accent font-semibold" : "text-white/80 transition-colors hover:text-white"}>All Calculators</a>
                  <a href="/about" class={normalizedPath === '/about' ? "text-accent font-semibold" : "text-white/80 transition-colors hover:text-white"}>About</a>
                  <a href="/contact" class={normalizedPath === '/contact' ? "text-accent font-semibold" : "text-white/80 transition-colors hover:text-white"}>Contact</a>
                </>
              );
            })()
          }
        </nav>
      </div>
    </header>
    <main class="flex-1">
      <slot />
    </main>
    <footer class="border-t border-border bg-navy text-white/70">
      <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
          <!-- Column 1 -->
          <div>
            <p class="font-heading text-lg font-bold text-white"><span class="text-accent">All</span>CalcNow</p>
            <p class="mt-2 text-sm">All Calculators. All Free. Right Now.</p>
            <p class="mt-4 text-xs text-white/50">
              &copy; {new Date().getFullYear()} AllCalcNow.com. All rights reserved.
            </p>
          </div>
          <!-- Column 2 -->
          <div>
            <p class="font-heading text-sm font-bold uppercase tracking-wider text-white">Popular Calculators</p>
            <ul class="mt-3 space-y-2 text-sm">
              <li><a href="/age-calculator" class="transition-colors hover:text-white hover:underline">Age Calculator</a></li>
              <li><a href="/mortgage-calculator" class="transition-colors hover:text-white hover:underline">Mortgage Calculator</a></li>
              <li><a href="/bmi-calculator" class="transition-colors hover:text-white hover:underline">BMI Calculator</a></li>
              <li><a href="/loan-calculator" class="transition-colors hover:text-white hover:underline">Loan Calculator</a></li>
              <li><a href="/compound-interest-calculator" class="transition-colors hover:text-white hover:underline">Compound Interest Calculator</a></li>
            </ul>
          </div>
          <!-- Column 3 -->
          <div>
            <p class="font-heading text-sm font-bold uppercase tracking-wider text-white">Company</p>
            <ul class="mt-3 space-y-2 text-sm">
              <li><a href="/about" class="transition-colors hover:text-white hover:underline">About</a></li>
              <li><a href="/contact" class="transition-colors hover:text-white hover:underline">Contact</a></li>
              <li><a href="/privacy-policy" class="transition-colors hover:text-white hover:underline">Privacy Policy</a></li>
            </ul>
          </div>
        </div>
        <!-- Bottom Bar -->
        <div class="mt-8 border-t border-white/10 pt-6 text-center text-xs text-white/40">
          All calculations on AllCalcNow are for reference purposes only. Always consult a professional for financial and medical decisions.
        </div>
      </div>
    </footer>
  </body>
</html>
