# Netlify _headers — per-path cache rules for HTML and robots.txt
# Docs: https://docs.netlify.com/routing/headers/
#
# NOTE: Security headers, /_astro/* and /sitemap*.xml headers are defined
# in netlify.toml [[headers]] blocks to keep everything in one place.

# ─── HTML pages: revalidate on every visit ───────────────────────────────────
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

# ─── robots.txt — short cache, correct Content-Type ─────────────────────────
# Content-Type must be explicit because X-Content-Type-Options: nosniff is set.
/robots.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8
